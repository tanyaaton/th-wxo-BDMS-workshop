{
  "openapi": "3.0.0",
  "info": {
    "title": "Gmail and Calendar Service API",
    "description": "API for sending emails and creating Google Calendar events",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://be-gmail.28fksfbqmbmw.us-south.codeengine.appdomain.cloud",
      "description": "Production server"
    }
  ],
  "paths": {
    "/send-email": {
      "post": {
        "tags": ["Email"],
        "summary": "Send an email via Gmail SMTP",
        "operationId": "sendEmail",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to", "subject", "body"],
                "properties": {
                  "to": {
                    "type": "string",
                    "description": "Recipient email address",
                    "example": "recipient@example.com"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Email subject",
                    "example": "Meeting Invitation"
                  },
                  "body": {
                    "type": "string",
                    "description": "Email body content",
                    "example": "You are invited to our meeting"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Email sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "Email sent successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/create-calendar-event": {
      "post": {
        "tags": ["Calendar"],
        "summary": "Create a Google Calendar event",
        "operationId": "createCalendarEvent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["summary", "description", "start", "end", "calendar_email"],
                "properties": {
                  "summary": {
                    "type": "string",
                    "description": "Event title/summary",
                    "example": "Procurement Meeting"
                  },
                  "description": {
                    "type": "string",
                    "description": "Event description",
                    "example": "Discuss procurement requirements"
                  },
                  "start": {
                    "type": "string",
                    "description": "Event start time in format YYYYMMDDTHHMMSS",
                    "example": "20260220T140000"
                  },
                  "end": {
                    "type": "string",
                    "description": "Event end time in format YYYYMMDDTHHMMSS",
                    "example": "20260220T150000"
                  },
                  "calendar_email": {
                    "type": "string",
                    "description": "Email address of the calendar where the event should be created (must be shared with the service account)",
                    "example": "demowxo45@gmail.com"
                  },
                  "timezone": {
                    "type": "string",
                    "description": "Timezone for the event",
                    "example": "Asia/Bangkok",
                    "default": "Asia/Bangkok"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Event created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "Event created: https://www.google.com/calendar/event?eid=..."
                    },
                    "calendar": {
                      "type": "string",
                      "example": "demowxo45@gmail.com"
                    },
                    "note": {
                      "type": "string",
                      "example": "Event created in specified calendar"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/send-email-and-calendar-event": {
      "post": {
        "tags": ["Combined"],
        "summary": "Send email and create calendar event",
        "operationId": "sendEmailAndCalendarEvent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["summary", "description", "start", "end", "email_attendees"],
                "properties": {
                  "summary": {
                    "type": "string",
                    "description": "Event title/summary (also used as email subject)",
                    "example": "Procurement Meeting"
                  },
                  "description": {
                    "type": "string",
                    "description": "Event description (also used as email body)",
                    "example": "Discuss procurement requirements"
                  },
                  "start": {
                    "type": "string",
                    "description": "Event start time in format YYYYMMDDTHHMMSS",
                    "example": "20260220T140000"
                  },
                  "end": {
                    "type": "string",
                    "description": "Event end time in format YYYYMMDDTHHMMSS",
                    "example": "20260220T150000"
                  },
                  "email_attendees": {
                    "type": "array",
                    "description": "List of attendee email addresses (for both email and calendar)",
                    "items": {
                      "type": "string"
                    },
                    "example": ["someone@example.com", "other@example.com"]
                  },
                  "timezone": {
                    "type": "string",
                    "description": "Timezone for the event",
                    "example": "Asia/Bangkok",
                    "default": "Asia/Bangkok"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Email sent and event created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "Email sent and event created: https://www.google.com/calendar/event?eid=..."
                    },
                    "note": {
                      "type": "string",
                      "example": "Email invitation was sent via SMTP, calendar event created without duplicate Google Calendar invites"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    }
  }
}